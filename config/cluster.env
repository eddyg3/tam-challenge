#!/usr/bin/env bash

CLUSTER_NAME="tam-kubeadm"
DOMAIN_SUFFIX="lab.local"

K8S_VERSION="1.32.0"
K8S_CHANNEL_VERSION="1.32"

CONTROL_PLANE_NAME="${CLUSTER_NAME}-cp-1"
WORKER_1_NAME="${CLUSTER_NAME}-worker-1"
WORKER_2_NAME="${CLUSTER_NAME}-worker-2"

VM_USER="${VM_USER:-${USER:-ubuntu}}"

LIBVIRT_NETWORK_NAME="default"

POD_CIDR="10.244.0.0/16"
SERVICE_CIDR="10.96.0.0/12"

VM_VCPU="2"
VM_MEMORY_MB="4096"
CONTROL_PLANE_DISK_GB="20"
WORKER_DISK_GB="15"

UBUNTU_RELEASE="22.04"
UBUNTU_CLOUD_IMAGE_URL="https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img"
UBUNTU_CLOUD_IMAGE_NAME="jammy-server-cloudimg-amd64.img"

NTP_SERVER="ntp.ubuntu.com"
PREPULL_KUBE_IMAGES="true"

CALICO_MANIFEST_FILE="./manifests/calico/calico-v3.28.0.yaml"

VIRT_DATA_ROOT="${VIRT_DATA_ROOT:-/var/lib/libvirt/${CLUSTER_NAME}}"

DATA_ROOT="${DATA_ROOT:-.runtime}"
ARTIFACTS_DIR="${ARTIFACTS_DIR:-${DATA_ROOT}/${CLUSTER_NAME}}"

BASE_IMAGE_DIR="${BASE_IMAGE_DIR:-${VIRT_DATA_ROOT}/images}"
VM_DISK_DIR="${VM_DISK_DIR:-${VIRT_DATA_ROOT}/vm-disks}"
CLOUD_INIT_DIR="${CLOUD_INIT_DIR:-${VIRT_DATA_ROOT}/cloud-init}"

KUBEADM_DIR="${KUBEADM_DIR:-${ARTIFACTS_DIR}/kubeadm}"
KUBECONFIG_DIR="${KUBECONFIG_DIR:-${ARTIFACTS_DIR}/kubeconfigs}"
PKI_DIR="${PKI_DIR:-${ARTIFACTS_DIR}/pki}"
LOG_DIR="${LOG_DIR:-${ARTIFACTS_DIR}/logs}"
RBAC_DIR="${RBAC_DIR:-${ARTIFACTS_DIR}/rbac}"
